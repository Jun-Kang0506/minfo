# MINFO — Claude API configuration (optional)
#
# The app works fully WITHOUT these values: without an API key, all answers
# come from the local source-grounded engine (src/lib/engine/localAnswerEngine.ts).
#
# To enable live Claude answers for free-typed questions:
#   1. Copy this file:            cp .env.local.example .env.local
#   2. Paste your API key from    https://platform.claude.com/  into ANTHROPIC_API_KEY
#   3. Restart the dev server:    npm run dev
#
# These variables are read ONLY server-side (src/app/api/ask/route.ts →
# src/lib/engine/claudeAnswerEngine.ts) and are never sent to the browser.
# .env.local is gitignored — never commit your key.
#
# If the key is missing or invalid, or any API call fails (rate limit,
# timeout, refusal), MINFO automatically falls back to the local engine.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
